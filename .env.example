# Copy to .env.local and fill in. See docs/PORTABILITY.md for where each is used.

# ── Supabase (REQUIRED) ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI (required for the chat widget & resource generation) ─────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional integrations ───────────────────────────────────────────
# EOW report text generation
GROQ_API_KEY=
# Google Drive (live SOP context for chat) + EOW Google Docs export.
# Paste the full service-account JSON as a single-line string.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_FOLDER_ID=
# Weekly health-check Slack notification
SLACK_BOT_TOKEN=
# Bearer secret protecting the /api/weekly-check cron route
WEEKLY_CHECK_SECRET=
# Secret for the service-to-service /api/external/provision-company route
PROVISION_SECRET=

# ── Deployment ──────────────────────────────────────────────────────
# Base URL for auth email redirects. SET THIS in any real deployment —
# otherwise it falls back to a hardcoded URL in config/brand.ts.
NEXT_PUBLIC_SITE_URL=https://your-portal.example.com
# Optional: company email domain (referenced in setup docs)
NEXT_PUBLIC_COMPANY_EMAIL_DOMAIN=example.com
